<DefaultWindow xmlns="https://spacestation14.io"
            xmlns:tabs="clr-namespace:Content.Client.Options.UI.Tabs"
            Title="{Loc 'ui-options-title'}"
            StyleIdentifier="mythosOptionsWindow"
            MinSize="800 450">
    <PanelContainer StyleIdentifier="mythosOptionsBodyPanel">
        <TabContainer Name="Tabs" Access="Public" StyleIdentifier="mythosOptionsTabs">
            <tabs:MiscTab Name="MiscTab" />
            <tabs:GraphicsTab Name="GraphicsTab" />
            <tabs:KeyRebindTab Name="KeyRebindTab" />
            <tabs:AudioTab Name="AudioTab" />
            <tabs:AccessibilityTab Name="AccessibilityTab" />
            <tabs:AdminOptionsTab Name="AdminOptionsTab" />
        </TabContainer>
    </PanelContainer>
</DefaultWindow>
