<screens:MythosGameScreen
    xmlns="https://spacestation14.io"
    xmlns:screens="clr-namespace:Content.Client._Mythos.UserInterface.Screens"
    xmlns:menuBar="clr-namespace:Content.Client.UserInterface.Systems.MenuBar.Widgets"
    xmlns:actions="clr-namespace:Content.Client.UserInterface.Systems.Actions.Widgets"
    xmlns:chat="clr-namespace:Content.Client.UserInterface.Systems.Chat.Widgets"
    xmlns:alerts="clr-namespace:Content.Client.UserInterface.Systems.Alerts.Widgets"
    xmlns:ghost="clr-namespace:Content.Client.UserInterface.Systems.Ghost.Widgets"
    xmlns:hotbar="clr-namespace:Content.Client.UserInterface.Systems.Hotbar.Widgets"
    xmlns:controls="clr-namespace:Content.Client.UserInterface.Controls"
    xmlns:inventory="clr-namespace:Content.Client.UserInterface.Systems.Inventory.Widgets"
    xmlns:vitals="clr-namespace:Content.Client._Mythos.UserInterface.Systems.Vitals.Widgets"
    xmlns:location="clr-namespace:Content.Client._Mythos.UserInterface.Systems.Location.Widgets"
    xmlns:character="clr-namespace:Content.Client._Mythos.UserInterface.Systems.Character.Widgets"
    xmlns:mythosChat="clr-namespace:Content.Client.Mythos.UserInterface.Chat"
    xmlns:mythosEquipment="clr-namespace:Content.Client.Mythos.UserInterface.Equipment"
    Name="MythosHud"
    VerticalExpand="False"
    VerticalAlignment="Bottom"
    HorizontalAlignment="Center">
    <LayoutContainer Name="ViewportContainer" HorizontalExpand="True" VerticalExpand="True">
        <controls:MainViewport Name="MainViewport" />
    </LayoutContainer>
    <LayoutContainer Name="OldHudRoot" Access="Protected" HorizontalExpand="True" VerticalExpand="True" Visible="False">
        <BoxContainer Name="TopLeft" Access="Protected" Orientation="Vertical">
            <BoxContainer Name="VoteMenu" Access="Public" Margin="0 10 0 10" Orientation="Vertical" />
            <actions:ActionsBar Name="Actions" Access="Protected" />
        </BoxContainer>
        <ghost:GhostGui Name="Ghost" Access="Protected" />
        <inventory:InventoryGui Name="Inventory" Access="Protected" />
        <alerts:AlertsUI Name="Alerts" Access="Protected" />
    </LayoutContainer>
    <LayoutContainer Name="MythosHudRoot" Access="Protected" HorizontalExpand="True" VerticalExpand="True">
        <mythosEquipment:MythosEquipmentPanel Name="EquipmentPanel"
                                              Access="Protected"
                                              HorizontalExpand="True"
                                              VerticalExpand="True">
            <character:CharacterPanel Name="Character" Access="Public" />
        </mythosEquipment:MythosEquipmentPanel>
        <vitals:VitalsOrbsBar Name="Vitals" Access="Public" />
        <mythosChat:MythosChatPanel Name="ChatPanel"
                                    Access="Protected"
                                    HorizontalExpand="True"
                                    VerticalExpand="True">
            <chat:ChatBox StyleClasses="ChatOutput"
                          Name="Chat"
                          Access="Protected"
                          HorizontalExpand="True"
                          VerticalExpand="True"
                          MinSize="0 0" />
        </mythosChat:MythosChatPanel>
        <!-- Mythos: top menu bar lives in MythosHudRoot (not OldHudRoot) so it stays
             visible/clickable when the legacy HUD overlay is hidden. Listed after the
             chrome panels so it renders on top of them. -->
        <menuBar:GameTopMenuBar Name="TopBar" Access="Public" />
        <location:LocationTimeWidget Name="LocationTime" Access="Public" />
    </LayoutContainer>
</screens:MythosGameScreen>
